# Copy this file to `.env.local` and fill in the real values. `.env.local`
# is gitignored — never commit it.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and anon (publishable) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Service-role key. Bypasses RLS — server-side only, never log or expose.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiJ9.<payload>.<signature>

# ── Database (Prisma) ────────────────────────────────────────────────────────
# Prefer Supabase's "Transaction Pooler" connection string. Direct (port 5432)
# also works but breaks if your network is IPv6-only.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000. Production: your deployed URL.
NEXTAUTH_URL=http://localhost:3000
# 32+ char random secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-real-random-string
