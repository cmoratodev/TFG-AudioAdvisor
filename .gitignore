# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — `.env.example` is the only one tracked (template, no secrets)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client (pinned to a stable path by `output =` in
# schema.prisma — see comment there). Regenerated on every `prisma generate`.
node_modules/.prisma

# Alternative package managers — we use pnpm, ignore stragglers from npm/yarn
package-lock.json
yarn.lock

# Editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Misc local dev artifacts
/src/generated/prisma
